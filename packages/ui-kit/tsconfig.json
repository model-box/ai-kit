{
  "extends": "@repo/typescript-config/react-library.json",
  "compilerOptions": {
    "importHelpers": true,
    "target": "es2015",
    "lib": ["dom", "es2015"],
    "module": "esnext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["."],
  "exclude": ["dist", "build", "node_modules"]
}
